# Local .terraform directories
.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version
# control as they are data points which are potentially sensitive and subject
# to change depending on the environment.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Include override files you do wish to add to version control using negated pattern
# !example_override.tf

# Saved plan files from `terraform plan -out=tfplan`. These are opaque binaries
# that embed resolved values — account IDs, ARNs, and any sensitive attribute —
# so they must never reach a public repository. Commit a redacted rendering under
# docs/plans/ instead, produced with `terraform show -no-color <planfile>`.
*tfplan*

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Partial backend configuration — holds the account-specific state bucket name
# and region. Commit backend.hcl.example instead.
backend.hcl

# Optional: ignore graph output files generated by `terraform graph`
# *.dot

# Plan files saved before a destroy carry the same sensitive contents as any
# other saved plan.
planout

# Node artifacts
node_modules/
.yarn/install-state.gz
.yarn/cache/
.yarn/*.log